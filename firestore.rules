rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is the admin
    function isAdmin() {
      // NOTE: Replace this with actual admin checks, such as using custom claims (request.auth.token.admin == true)
      // Since your app currently relies on this specific email for admin privileges:
      return request.auth != null && request.auth.token.email == 'lrodricg30@gmail.com';
    }

    // Helper function to check if user is logged in
    function isAuthenticated() {
      return request.auth != null;
    }

    // Users collection
    match /users/{userId} {
      // Users can read all users (needed for the friends panel to list users). 
      // Users can only write their own document (e.g. updating balance during a purchase).
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // Products collection (Catalog)
    match /products/{productId} {
      // Anyone can read products
      allow read: if true;
      // Only admins can modify products
      allow write: if isAdmin();
    }

    // Products Stock collection
    match /products_stock/{productId} {
      // Anyone can read stock status
      allow read: if true;
      // Users need to be able to UPDATE stock when they make a purchase (to pull credentials).
      allow update: if isAuthenticated();
      // Only admins can create or delete stock documents
      allow create, delete: if isAdmin();
    }

    // Orders collection
    match /orders/{orderId} {
      // Users can read their own orders. Admins can read all orders.
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      // Users can create an order
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      // Only admins can update or delete orders (e.g., to confirm delivery)
      allow update, delete: if isAdmin();
    }
    
    // Reviews collection
    match /reviews/{reviewId} {
      // Anyone can read reviews
      allow read: if true;
      // Authenticated users can create reviews
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      // Only admins or the author can edit/delete reviews
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
    }
    
    // Balance Requests collection
    match /balance_requests/{requestId} {
      // Users can read their own balance requests. Admins can read all.
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      // Users can create a balance request
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      // Only admins can modify/delete balance requests
      allow update, delete: if isAdmin();
    }

    // Friendships collection
    match /friendships/{friendshipId} {
      // Users can read if they are one of the parties involved
      allow read: if isAuthenticated() && (resource.data.uid1 == request.auth.uid || resource.data.uid2 == request.auth.uid);
      // Users can create a friendship request if they are uid1
      allow create: if isAuthenticated() && request.resource.data.uid1 == request.auth.uid;
      // Users can update if they are uid2 (accepting) or uid1 (canceling)
      allow update, delete: if isAuthenticated() && (resource.data.uid1 == request.auth.uid || resource.data.uid2 == request.auth.uid);
    }

    // Payment Methods collection
    match /payment_methods/{methodId} {
      // Anyone can read available payment methods
      allow read: if true;
      // Only admins can edit payment methods
      allow write: if isAdmin();
    }
  }
}
