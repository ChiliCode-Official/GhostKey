rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is the admin
    function isAdmin() {
      // NOTE: Replace this with actual admin checks, such as using custom claims (request.auth.token.admin == true)
      // Since your app currently relies on this specific email for admin privileges:
      return request.auth != null && request.auth.token.email == 'lrodricg30@gmail.com';
    }

    // Helper function to check if user is logged in
    function isAuthenticated() {
      return request.auth != null;
    }

    // Users collection
    match /users/{userId} {
      // Users can read and write their own documents. Admins can read and write all.
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // Products collection (Catalog)
    match /products/{productId} {
      // Anyone can read products
      allow read: if true;
      // Only admins can modify products
      allow write: if isAdmin();
    }

    // Products Stock collection
    match /products_stock/{productId} {
      // Anyone can read stock status
      allow read: if true;
      // Only admins can modify stock (like adding/removing credentials)
      allow write: if isAdmin();
    }

    // Orders collection
    match /orders/{orderId} {
      // Users can read their own orders. Admins can read all orders.
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      // Users can create an order
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      // Only admins can update or delete orders (e.g., to confirm delivery)
      allow update, delete: if isAdmin();
    }

    // Friendships collection
    match /friendships/{friendshipId} {
      // Users can read if they are one of the parties involved
      allow read: if isAuthenticated() && (resource.data.uid1 == request.auth.uid || resource.data.uid2 == request.auth.uid);
      // Users can create a friendship request if they are uid1
      allow create: if isAuthenticated() && request.resource.data.uid1 == request.auth.uid;
      // Users can update if they are uid2 (accepting) or uid1 (canceling)
      allow update: if isAuthenticated() && (resource.data.uid1 == request.auth.uid || resource.data.uid2 == request.auth.uid);
      allow delete: if isAuthenticated() && (resource.data.uid1 == request.auth.uid || resource.data.uid2 == request.auth.uid);
    }

    // Payment Methods collection
    match /payment_methods/{methodId} {
      // Anyone can read available payment methods
      allow read: if true;
      // Only admins can edit payment methods
      allow write: if isAdmin();
    }
  }
}
